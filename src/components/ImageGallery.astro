---
// Componente de galeria de imagens com modal, zoom e pan
// Aplica automaticamente a todas as imagens dentro do slot
---

<div class="image-gallery-wrapper">
  <slot />
</div>

<div id="image-gallery-modal" class="image-modal" role="dialog" aria-modal="true" aria-label="Galeria de imagens">
  <button class="modal-close" aria-label="Fechar galeria">×</button>
  <div class="modal-controls">
    <button class="zoom-in" aria-label="Aumentar zoom">+</button>
    <button class="zoom-out" aria-label="Diminuir zoom">−</button>
    <button class="zoom-reset" aria-label="Resetar zoom">⟲</button>
  </div>
  <img src="" alt="" class="modal-image" />
</div>

<style is:global>
  /* Modal */
  .image-modal {
    display: none;
    opacity: 0;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    background-color: rgba(0, 0, 0, 0.97);
    align-items: center;
    justify-content: center;
    padding: 1rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .image-modal {
      padding: 2rem;
      cursor: zoom-out;
    }
  }

  .image-modal.active {
    display: flex;
    opacity: 1;
    transition: opacity 200ms cubic-bezier(0.23, 1, 0.32, 1);
    @starting-style {
      opacity: 0;
    }
  }

  /* entrada via animation (roda uma vez) para não brigar com a
     transition de transform do zoom/pan */
  .image-modal.active .modal-image {
    animation: modalImgIn 250ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  @keyframes modalImgIn {
    from { transform: scale(0.97); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .image-modal.active .modal-image {
      animation: none;
    }
  }

  .modal-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
    transition: transform 0.1s ease-out;
    touch-action: pan-x pan-y pinch-zoom;
    user-select: none;
  }

  @media (min-width: 768px) {
    .modal-image {
      cursor: grab;
      max-width: 90%;
      max-height: 90%;
    }

    .modal-image:active {
      cursor: grabbing;
    }
  }

  /* Botão de fechar */
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: background-color 200ms ease, transform 160ms cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 768px) {
    .modal-close {
      top: 1.5rem;
      right: 1.5rem;
      width: 3rem;
      height: 3rem;
      font-size: 2rem;
    }

    .modal-close:hover {
      background: rgba(255, 255, 255, 0.25);
      transform: scale(1.1);
    }
  }

  /* Controles de zoom */
  .modal-controls {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 2rem;
    padding: 0.5rem;
    z-index: 10000;
  }

  @media (min-width: 768px) {
    .modal-controls {
      bottom: 2rem;
    }
  }

  .modal-controls button {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    font-size: 1.25rem;
    cursor: pointer;
    transition: background-color 200ms ease, transform 160ms cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 768px) {
    .modal-controls button:hover {
      background: rgba(255, 255, 255, 0.25);
      transform: scale(1.1);
    }
  }

  /* Imagens clicáveis (também focáveis via teclado, ver script) */
  .image-gallery-wrapper img {
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  @media (min-width: 768px) {
    .image-gallery-wrapper img {
      cursor: zoom-in;
    }

    .image-gallery-wrapper img:hover {
      transform: scale(1.02);
      box-shadow: 0 25px 30px -5px rgb(0 0 0 / 0.2), 0 10px 15px -6px rgb(0 0 0 / 0.15);
    }
  }

  .image-gallery-wrapper img:focus-visible {
    transform: scale(1.02);
    box-shadow: 0 25px 30px -5px rgb(0 0 0 / 0.2), 0 10px 15px -6px rgb(0 0 0 / 0.15);
  }
</style>

<script>
  // Configuração da galeria de imagens
  class ImageGallery {
    private modal: HTMLElement | null = null;
    private modalImg: HTMLImageElement | null = null;
    private scale: number = 1;
    private translateX: number = 0;
    private translateY: number = 0;
    private isDragging: boolean = false;
    private startX: number = 0;
    private startY: number = 0;
    private initialDistance: number = 0;
    private initialScale: number = 1;
    private lastTouchX: number = 0;
    private lastTouchY: number = 0;
    private lastFocused: HTMLElement | null = null;

    constructor() {
      this.init();
    }

    init() {
      this.modal = document.getElementById('image-gallery-modal');
      this.modalImg = this.modal?.querySelector('.modal-image') as HTMLImageElement;

      if (!this.modal || !this.modalImg) return;

      this.setupImageListeners();
      this.setupModalListeners();
      this.setupControlListeners();
    }

    setupImageListeners() {
      const images = document.querySelectorAll('.image-gallery-wrapper img');
      images.forEach(img => {
        // torna a imagem focável e ativável por teclado (Enter/Espaço),
        // já que o clique sozinho não é alcançável sem mouse
        if (!img.hasAttribute('tabindex')) img.setAttribute('tabindex', '0');
        img.setAttribute('role', 'button');
        if (!img.hasAttribute('aria-label')) {
          const alt = img.getAttribute('alt');
          img.setAttribute('aria-label', alt ? `Ampliar imagem: ${alt}` : 'Ampliar imagem');
        }

        img.addEventListener('click', (e) => {
          e.preventDefault();
          this.openModal(e.target as HTMLImageElement);
        });

        img.addEventListener('keydown', (e) => {
          const key = (e as KeyboardEvent).key;
          if (key === 'Enter' || key === ' ') {
            e.preventDefault();
            this.openModal(img as HTMLImageElement);
          }
        });
      });
    }

    setupModalListeners() {
      if (!this.modal || !this.modalImg) return;

      // Fechar ao clicar no fundo
      this.modal.addEventListener('click', (e) => {
        if (e.target === this.modal) {
          this.closeModal();
        }
      });

      // Fechar com botão
      const closeBtn = this.modal.querySelector('.modal-close');
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.closeModal();
      });

      // Fechar com ESC, e prender o Tab dentro do modal enquanto aberto
      document.addEventListener('keydown', (e) => {
        if (!this.modal?.classList.contains('active')) return;
        if (e.key === 'Escape') {
          this.closeModal();
        } else if (e.key === 'Tab') {
          this.trapTab(e);
        }
      });

      // Zoom com scroll (desktop)
      this.modalImg.addEventListener('wheel', (e) => this.handleWheel(e), { passive: false });

      // Arrastar (desktop)
      this.modalImg.addEventListener('mousedown', (e) => this.handleMouseDown(e));
      document.addEventListener('mousemove', (e) => this.handleMouseMove(e));
      document.addEventListener('mouseup', () => this.handleMouseUp());

      // Touch (mobile)
      this.modalImg.addEventListener('touchstart', (e) => this.handleTouchStart(e), { passive: false });
      this.modalImg.addEventListener('touchmove', (e) => this.handleTouchMove(e), { passive: false });
      this.modalImg.addEventListener('touchend', () => this.handleTouchEnd());
    }

    setupControlListeners() {
      const zoomIn = this.modal?.querySelector('.zoom-in');
      const zoomOut = this.modal?.querySelector('.zoom-out');
      const zoomReset = this.modal?.querySelector('.zoom-reset');

      zoomIn?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.adjustZoom(0.3);
      });
      zoomOut?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.adjustZoom(-0.3);
      });
      zoomReset?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.resetZoom();
      });
    }

    getFocusableElements(): HTMLElement[] {
      if (!this.modal) return [];
      return Array.from(
        this.modal.querySelectorAll<HTMLElement>('button')
      );
    }

    trapTab(e: KeyboardEvent) {
      const focusable = this.getFocusableElements();
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    openModal(img: HTMLImageElement) {
      if (!this.modal || !this.modalImg) return;

      this.lastFocused = document.activeElement as HTMLElement;
      this.modalImg.src = img.src;
      this.modalImg.alt = img.alt;
      this.modal.classList.add('active');
      this.resetZoom();

      // Bloquear scroll do body
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.height = '100%';

      this.modal.querySelector<HTMLElement>('.modal-close')?.focus();
    }

    closeModal() {
      if (!this.modal) return;

      this.modal.classList.remove('active');
      this.resetZoom();

      // Restaurar scroll do body
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.height = '';

      this.lastFocused?.focus();
      this.lastFocused = null;
    }

    updateTransform() {
      if (!this.modalImg) return;
      this.modalImg.style.transform = `translate(${this.translateX}px, ${this.translateY}px) scale(${this.scale})`;
    }

    adjustZoom(delta: number) {
      this.scale = Math.min(Math.max(1, this.scale + delta), 5);
      if (this.scale === 1) {
        this.translateX = 0;
        this.translateY = 0;
      }
      this.updateTransform();
    }

    resetZoom() {
      this.scale = 1;
      this.translateX = 0;
      this.translateY = 0;
      this.updateTransform();
    }

    handleWheel(e: WheelEvent) {
      e.preventDefault();
      const delta = e.deltaY > 0 ? -0.1 : 0.1;
      this.adjustZoom(delta);
    }

    handleMouseDown(e: MouseEvent) {
      if (this.scale > 1) {
        e.preventDefault();
        this.isDragging = true;
        this.startX = e.clientX - this.translateX;
        this.startY = e.clientY - this.translateY;
      }
    }

    handleMouseMove(e: MouseEvent) {
      if (this.isDragging) {
        this.translateX = e.clientX - this.startX;
        this.translateY = e.clientY - this.startY;
        this.updateTransform();
      }
    }

    handleMouseUp() {
      this.isDragging = false;
    }

    handleTouchStart(e: TouchEvent) {
      if (e.touches.length === 2) {
        // Pinch zoom
        e.preventDefault();
        const touch1 = e.touches[0];
        const touch2 = e.touches[1];
        this.initialDistance = Math.hypot(
          touch2.clientX - touch1.clientX,
          touch2.clientY - touch1.clientY
        );
        this.initialScale = this.scale;
      } else if (e.touches.length === 1 && this.scale > 1) {
        // Pan com um dedo quando há zoom
        e.preventDefault();
        const touch = e.touches[0];
        this.lastTouchX = touch.clientX;
        this.lastTouchY = touch.clientY;
        this.isDragging = true;
      }
    }

    handleTouchMove(e: TouchEvent) {
      if (e.touches.length === 2) {
        // Pinch zoom
        e.preventDefault();
        const touch1 = e.touches[0];
        const touch2 = e.touches[1];
        const currentDistance = Math.hypot(
          touch2.clientX - touch1.clientX,
          touch2.clientY - touch1.clientY
        );
        this.scale = Math.min(
          Math.max(1, this.initialScale * (currentDistance / this.initialDistance)),
          5
        );
        if (this.scale === 1) {
          this.translateX = 0;
          this.translateY = 0;
        }
        this.updateTransform();
      } else if (e.touches.length === 1 && this.isDragging && this.scale > 1) {
        // Pan com um dedo
        e.preventDefault();
        const touch = e.touches[0];
        const deltaX = touch.clientX - this.lastTouchX;
        const deltaY = touch.clientY - this.lastTouchY;
        this.translateX += deltaX;
        this.translateY += deltaY;
        this.lastTouchX = touch.clientX;
        this.lastTouchY = touch.clientY;
        this.updateTransform();
      }
    }

    handleTouchEnd() {
      this.isDragging = false;
    }
  }

  // Inicializar quando o DOM estiver pronto
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new ImageGallery());
  } else {
    new ImageGallery();
  }
</script>
