---
import TagBadges from './TagBadges.astro';

interface Props {
  nome: string;
  descricao: string;
  tags: string[];
  url: string;
  maxTags?: number;
  headingLevel?: 'h2' | 'h3';
}

const { nome, descricao, tags, url, maxTags, headingLevel = 'h2' } = Astro.props;
const Titulo = headingLevel;
---

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 rounded-2xl card-animate">
  <div class="card-body p-6 flex flex-col">
    <div class="flex items-start justify-between mb-3">
      <Titulo class="card-title text-xl font-semibold flex-1">{nome}</Titulo>
    </div>

    <p class="text-base-content/70 text-sm leading-relaxed mb-4">
      {descricao}
    </p>

    <div class="mb-6">
      <TagBadges tags={tags} maxTags={maxTags} />
    </div>

    <div class="card-actions justify-end mt-auto">
      <a href={url} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
        Ver Projeto
      </a>
    </div>
  </div>
</div>
