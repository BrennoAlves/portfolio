---
interface Props {
  titulo: string;
  descricao: string;
  tags: string[];
  url: string;
  imagemCapa?: string;
  maxTags?: number;
}

const { titulo, descricao, tags, url, imagemCapa, maxTags } = Astro.props;
const displayTags = maxTags ? tags.slice(0, maxTags) : tags;
---

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 rounded-2xl card-animate">
  {imagemCapa && (
    <figure class="h-48 overflow-hidden">
      <img
        src={imagemCapa}
        alt={titulo}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </figure>
  )}
  <div class="card-body p-6 flex flex-col">
    <div class="flex items-start justify-between mb-3">
      <h2 class="card-title text-xl font-semibold flex-1">{titulo}</h2>
    </div>

    <p class="text-base-content/70 text-sm leading-relaxed mb-4">
      {descricao}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {displayTags.map((tag, indice) => (
        <div class={`badge ${
          indice % 4 === 0 ? 'bg-primary/20 text-primary' :
          indice % 4 === 1 ? 'bg-secondary/20 text-secondary' :
          indice % 4 === 2 ? 'bg-accent/20 text-accent' : 'bg-info/20 text-info'
        }`}>
          {tag}
        </div>
      ))}
    </div>

    <div class="card-actions justify-end mt-auto">
      <a href={url} class="btn btn-outline btn-sm">
        Ler Pesquisa
      </a>
    </div>
  </div>
</div>
