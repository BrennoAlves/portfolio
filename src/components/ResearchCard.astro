---
import { Image } from 'astro:assets';
import TagBadges from './TagBadges.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  titulo: string;
  descricao: string;
  tags: string[];
  url: string;
  imagemCapa?: ImageMetadata;
  maxTags?: number;
  includeDate?: string;
  headingLevel?: 'h2' | 'h3';
  ctaLabel?: string;
}

const { titulo, descricao, tags, url, imagemCapa, maxTags, includeDate, headingLevel = 'h2', ctaLabel = 'Ler Pesquisa' } = Astro.props;
const slug = url.split('/').filter(Boolean).pop();
const Titulo = headingLevel;
---

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 rounded-2xl card-animate">
  {imagemCapa && (
    <figure class="h-48 overflow-hidden">
      <Image
        src={imagemCapa}
        alt={titulo}
        class="w-full h-full object-cover transition-transform duration-300 md:hover:scale-105"
        loading="lazy"
        decoding="async"
        widths={[240, 480]}
        sizes="(min-width: 768px) 480px, 100vw"
      />
    </figure>
  )}
  <div class="card-body p-6 flex flex-col">
    <div class="flex items-start justify-between mb-3">
      <Titulo class="card-title text-xl font-semibold flex-1" transition:name={`pesquisa-titulo-${slug}`}>{titulo}</Titulo>
    </div>

    <p class="text-base-content/70 text-sm leading-relaxed mb-4">
      {descricao}
    </p>

    <div class="mb-6">
      <TagBadges tags={tags} maxTags={maxTags} includeDate={includeDate} />
    </div>

    <div class="card-actions justify-end mt-auto">
      <a href={url} class="btn btn-outline btn-sm">
        {ctaLabel}
      </a>
    </div>
  </div>
</div>
