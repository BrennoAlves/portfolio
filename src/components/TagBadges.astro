---
export interface Props {
  tags: string[];
  maxTags?: number;
  includeDate?: string;
  size?: 'md' | 'lg';
}

const { tags, maxTags = tags.length, includeDate, size = 'md' } = Astro.props;

const getBadgeColor = (index: number): string => {
  const colors = [
    'badge-primary',
    'badge-secondary',
    'badge-accent',
    'badge-info'
  ];
  return colors[index % 4];
};

const sizeClass = size === 'lg' ? 'badge-lg' : '';
---

<div class="flex flex-wrap gap-2">
  {tags.slice(0, maxTags).map((tag, index) => (
    <div class={`badge font-medium ${sizeClass} ${getBadgeColor(index)}`}>
      {tag}
    </div>
  ))}
  {includeDate && (
    <div class={`badge badge-warning font-medium ${sizeClass}`}>
      {includeDate}
    </div>
  )}
</div>
