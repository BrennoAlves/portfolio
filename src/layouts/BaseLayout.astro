---
const { pathname } = Astro.url;
const isProjetos = pathname.includes('/projetos');
const isPesquisas = pathname.includes('/pesquisas');
const titulo = isProjetos ? 'Criando' : isPesquisas ? 'Investigando' : 'Bem-vindo';
---

<canvas id="data-field" transition:persist="data-field" aria-hidden="true"></canvas>
<div class="container">
  <header class="header" transition:name="site-header">
    <a href="/" class="logo">{titulo}</a>
    <nav class="nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/projetos">Projetos</a></li>
        <li><a href="/pesquisas">Pesquisas</a></li>
        <li>
          <button id="theme-toggle" data-cuelume-toggle aria-label="Alternar tema claro/escuro">◐</button>
        </li>
      </ul>
    </nav>
  </header>
  <slot />
</div>

<style is:global>
  :root {
    --ease-out-strong: cubic-bezier(0.23, 1, 0.32, 1);
    --ease-in-out-strong: cubic-bezier(0.77, 0, 0.175, 1);
    --dur-fast: 150ms;
    --dur-base: 250ms;
    --dur-slow: 450ms;
  }

  .btn {
    border-radius: 80px;
    transition: transform 160ms var(--ease-out-strong);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-outline {
    border-width: 1px;
  }

  .badge {
    border-width: 1px;
  }

  .container {
    max-width: 64rem;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    padding: 2rem 2.5rem;
  }
  
  @media (min-width: 768px) {
    .container {
      gap: 5rem;
      padding: 4rem 2.5rem;
    }
  }
  
  .header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      padding-bottom: 0;
    }
  }

  .logo {
    font-size: 1.25rem;
    line-height: 1.75rem;
  }
  
  .nav {
    font-size: 0.875rem;
    line-height: 1.25rem;
    padding-top: 0.5%;
  }
  
  .nav ul {
    display: flex;
    align-items: center;
    white-space: nowrap;
    min-height: min-content;
  }
  
  .nav li {
    display: flex;
    align-items: center;
  }
  
  .nav a {
    display: flex;
    cursor: pointer;
    align-items: center;
    position: relative;
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms var(--ease-out-strong);
  }

  @media (hover: hover) and (pointer: fine) {
    .nav a:hover::after {
      transform: scaleX(1);
    }
  }
  
  .nav li + li:before {
    content: "/";
    margin: 0 0.5rem 0 0.75rem;
    opacity: 0.4;
  }

  /* campo de dados vivo — atrás de tudo */
  #data-field {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  #theme-toggle {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0.125rem;
    font-size: 1rem;
    line-height: 1;
    color: inherit;
    transition: transform 400ms var(--ease-out-strong);
  }

  [data-theme="business"] #theme-toggle {
    transform: rotate(180deg);
  }

  /* spotlight que segue o cursor nos cards */
  @media (hover: hover) and (pointer: fine) {
    :root .card {
      position: relative;
    }

    :root .card::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(
        320px circle at var(--mx, 50%) var(--my, 50%),
        color-mix(in oklch, var(--color-primary) 14%, transparent),
        transparent 65%
      );
      opacity: 0;
      transition: opacity 300ms ease;
      pointer-events: none;
    }

    :root .card:hover::after {
      opacity: 1;
    }
  }

  /* troca de tema: reveal circular a partir do botão */
  html.theme-switching::view-transition-old(root) {
    animation: none;
  }

  html.theme-switching::view-transition-new(root) {
    animation: themeReveal 500ms var(--ease-out-strong) both;
    clip-path: circle(0px at var(--reveal-x, 50%) var(--reveal-y, 0%));
  }

  @keyframes themeReveal {
    to {
      clip-path: circle(150vmax at var(--reveal-x, 50%) var(--reveal-y, 0%));
    }
  }
  
  /* cards entram quando aparecem no viewport (observer no fim deste arquivo) */
  .js .card-animate {
    opacity: 0;
  }

  .card-animate.in-view {
    animation: cardIn var(--dur-slow) var(--ease-out-strong) both;
  }

  .card-animate:nth-child(1) { animation-delay: 40ms; }
  .card-animate:nth-child(2) { animation-delay: 80ms; }
  .card-animate:nth-child(3) { animation-delay: 120ms; }
  .card-animate:nth-child(4) { animation-delay: 160ms; }
  .card-animate:nth-child(n+5) { animation-delay: 200ms; }

  /* reveal genérico ao rolar: <el data-reveal style="--reveal-i:N"> */
  .js [data-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 700ms var(--ease-out-strong),
      transform 700ms var(--ease-out-strong);
    transition-delay: calc(var(--reveal-i, 0) * 90ms);
  }

  .js [data-reveal].in-view {
    opacity: 1;
    transform: none;
  }

  /* cards com vida no hover (só ponteiro fino) */
  @media (hover: hover) and (pointer: fine) {
    :root .card {
      transition:
        transform 250ms var(--ease-out-strong),
        box-shadow 250ms ease;
    }

    :root .card:hover {
      transform: translateY(-4px);
    }
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOnly {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    /* manter opacidade (comunicação), remover deslocamento */
    .card-animate.in-view {
      animation-name: fadeOnly;
    }
    .js [data-reveal] {
      transform: none;
    }
    :root .card:hover {
      transform: none;
    }
    ::view-transition-old(root),
    ::view-transition-new(root),
    ::view-transition-group(*) {
      animation: none;
    }
    .nav a::after {
      transition: none;
    }
  }
</style>

<script>
  import { bind } from 'cuelume';

  // ── quincunx: o Teorema Central do Limite, ao vivo ─────────────────────
  // Pontos nascem no centro do topo, fazem passeio aleatório numa malha de
  // pinos quase invisível e empilham uma normal no rodapé. O cursor desvia
  // pontos na queda: viés de seleção interativo.
  function startQuincunx() {
    const canvas = document.getElementById('data-field');
    if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.on) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    canvas.dataset.on = '1';
    const cv = canvas; // narrowing não sobrevive a closures
    const ctx = cv.getContext('2d');
    if (!ctx) return;
    const g = ctx;

    const mobile = window.matchMedia('(pointer: coarse)').matches;
    const MAX_BALLS = mobile ? 30 : 70;
    const SPAWN_MS = mobile ? 900 : 450;
    const balls: { x: number; y: number; vx: number; vy: number }[] = [];
    const mouse = { x: -99999, y: -99999 };
    let w = 0, h = 0, dpr = 1;
    let cols = 0, colW = 0;
    let counts: number[] = [];
    let pegRows: number[] = [];
    let pegGapX = 0;
    let lastSpawn = 0;

    function resize() {
      // viewport 0 acontece em prerender/background — não zerar o canvas
      if (!window.innerWidth || !window.innerHeight) return;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = cv.width = window.innerWidth * dpr;
      h = cv.height = window.innerHeight * dpr;
      cv.style.width = window.innerWidth + 'px';
      cv.style.height = window.innerHeight + 'px';
      cols = Math.max(12, Math.round(window.innerWidth / 56));
      colW = w / cols;
      // a máquina já estava rodando antes de você abrir: sino parcial pré-semeado
      const teto = h * 0.16;
      const sigma = cols / 7;
      counts = Array.from({ length: cols }, (_, c) => {
        const z = (c - (cols - 1) / 2) / sigma;
        return teto * 0.5 * Math.exp(-0.5 * z * z) * (0.8 + Math.random() * 0.4);
      });
      // malha de pinos: da faixa 18% a 62% da altura
      pegRows = [];
      const nRows = 8;
      for (let r = 0; r < nRows; r++) pegRows.push(h * (0.18 + (r * 0.44) / (nRows - 1)));
      pegGapX = w / 24;
    }

    resize();
    window.addEventListener('resize', resize, { passive: true });

    // dono do hero, fantasma no resto: desvanece conforme o scroll
    function fadePorScroll() {
      const p = Math.min(1, window.scrollY / (window.innerHeight * 0.8));
      cv.style.opacity = String(1 - p * 0.88); // nunca abaixo de 0.12
    }
    fadePorScroll();
    window.addEventListener('scroll', fadePorScroll, { passive: true });
    document.addEventListener('astro:page-load', fadePorScroll);

    if (!mobile) {
      window.addEventListener('pointermove', (e) => {
        mouse.x = e.clientX * dpr;
        mouse.y = e.clientY * dpr;
      }, { passive: true });
    }

    let running = true;
    document.addEventListener('visibilitychange', () => {
      const estava = running;
      running = !document.hidden;
      if (running && !estava) tick(performance.now());
    });

    function tick(agora: number) {
      if (!running) return;
      if (!w || !h) {
        resize();
        requestAnimationFrame(tick);
        return;
      }
      g.clearRect(0, 0, w, h);
      const dark = document.documentElement.getAttribute('data-theme') === 'business';
      const rgb = dark ? '129, 161, 193' : '94, 129, 172';

      // nasce no centro do topo — o passeio aleatório constrói o sino
      if (agora - lastSpawn > SPAWN_MS && balls.length < MAX_BALLS) {
        lastSpawn = agora;
        balls.push({
          x: w / 2 + (Math.random() - 0.5) * w * 0.04,
          y: -4 * dpr,
          vx: 0,
          vy: (0.6 + Math.random() * 0.4) * dpr,
        });
      }

      // pinos: presença sutil, quase subliminar
      g.fillStyle = `rgba(${rgb}, ${dark ? 0.10 : 0.08})`;
      for (const py of pegRows) {
        const desloca = (pegRows.indexOf(py) % 2) * pegGapX * 0.5;
        for (let px = desloca; px <= w; px += pegGapX) {
          g.beginPath();
          g.arc(px, py, 0.9 * dpr, 0, 6.2832);
          g.fill();
        }
      }

      const chao = h - 6 * dpr;
      const gravidade = 0.045 * dpr;
      const vyMax = 2.6 * dpr;

      for (let i = balls.length - 1; i >= 0; i--) {
        const b = balls[i];
        const yAntes = b.y;
        b.vy = Math.min(vyMax, b.vy + gravidade);
        // cursor desvia a queda (viés de seleção)
        const dx = b.x - mouse.x;
        const dy = b.y - mouse.y;
        const dm = Math.hypot(dx, dy);
        if (dm < 120 * dpr && dm > 0.01) {
          b.vx += (dx / dm) * 0.22 * dpr;
        }
        // cruzou uma fileira de pinos → nudge binomial
        for (const py of pegRows) {
          if (yAntes < py && b.y >= py) {
            b.vx += (Math.random() < 0.5 ? -1 : 1) * (0.55 + Math.random() * 0.25) * dpr;
          }
        }
        b.vx *= 0.96;
        b.x += b.vx;
        b.y += b.vy;
        if (b.x < 2 * dpr) { b.x = 2 * dpr; b.vx = Math.abs(b.vx); }
        if (b.x > w - 2 * dpr) { b.x = w - 2 * dpr; b.vx = -Math.abs(b.vx); }

        const alturaBarra = (counts[Math.floor(b.x / colW)] || 0);
        if (b.y >= chao - alturaBarra) {
          // aterrissou: vira histograma
          const bin = Math.max(0, Math.min(cols - 1, Math.floor(b.x / colW)));
          counts[bin] += 7 * dpr;
          balls.splice(i, 1);
          continue;
        }
        g.fillStyle = `rgba(${rgb}, ${dark ? 0.65 : 0.55})`;
        g.beginPath();
        g.arc(b.x, b.y, 1.7 * dpr, 0, 6.2832);
        g.fill();
      }

      // histograma vivo: sobe com as aterrissagens, respira com decay lento
      const alturaTeto = h * 0.16;
      for (let c = 0; c < cols; c++) {
        counts[c] = Math.min(alturaTeto, counts[c]) * 0.9996;
        const alt = counts[c];
        if (alt < 1) continue;
        // barra desvanece rumo ao topo — sem borda dura, sem "coluna de sombra"
        const grad = g.createLinearGradient(0, chao - alt, 0, chao);
        grad.addColorStop(0, `rgba(${rgb}, 0)`);
        grad.addColorStop(1, `rgba(${rgb}, ${dark ? 0.14 : 0.09})`);
        g.fillStyle = grad;
        g.fillRect(c * colW + 1 * dpr, chao - alt, colW - 2 * dpr, alt);
      }

      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  startQuincunx();

  // easter egg pra quem abre o console (dev reconhece dev)
  if (!(window as any).__egg) {
    (window as any).__egg = 1;
    console.log(
      '%cPrazer, Brenno.%c\n\n' +
      '   /\\_/\\     A gata gorda supervisionou\n' +
      '  ( -.- )    cada linha deste site.\n' +
      '   =( I )=\n\n' +
      'A chuva de pontos aí atrás é um quincunx: passeio aleatório\n' +
      'formando uma normal — TCL ao vivo. Mexa o mouse na queda\n' +
      'e você vira viés de seleção.\n\n' +
      '🍞 pão de fermentação natural  🎸 baixo  📊 dados\n' +
      '→ brenno1231@outlook.com | github.com/BrennoAlves',
      'font-size: 18px; font-weight: 700; color: #5E81AC;',
      'font-size: 12px; color: inherit;'
    );
  }

  // ── spotlight nos cards (uma var CSS por card, paint-only) ─────────────
  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.addEventListener('pointermove', (e) => {
      const card = e.target instanceof Element ? e.target.closest('.card') : null;
      if (!(card instanceof HTMLElement)) return;
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${((e.clientX - r.left) / r.width) * 100}%`);
      card.style.setProperty('--my', `${((e.clientY - r.top) / r.height) * 100}%`);
    }, { passive: true });
  }

  // ── toggle de tema com reveal circular ─────────────────────────────────
  document.addEventListener('click', (e) => {
    const btn = e.target instanceof Element ? e.target.closest('#theme-toggle') : null;
    if (!btn) return;
    const html = document.documentElement;
    const next = html.getAttribute('data-theme') === 'business' ? 'nord' : 'business';
    try { localStorage.setItem('tema', next); } catch {}
    const aplica = () => html.setAttribute('data-theme', next);
    if (!document.startViewTransition || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      aplica();
      return;
    }
    const r = btn.getBoundingClientRect();
    html.style.setProperty('--reveal-x', `${r.left + r.width / 2}px`);
    html.style.setProperty('--reveal-y', `${r.top + r.height / 2}px`);
    html.classList.add('theme-switching');
    document.startViewTransition(aplica).finished.finally(() => {
      html.classList.remove('theme-switching');
    });
  });

  // sons sutis de interação: nav (tick), botões (press/release), galeria (bloom)
  function decorateSounds() {
    document.querySelectorAll('.nav a').forEach((el) => {
      el.setAttribute('data-cuelume-hover', 'tick');
    });
    document.querySelectorAll('.btn').forEach((el) => {
      el.setAttribute('data-cuelume-press', 'press');
      el.setAttribute('data-cuelume-release', 'release');
    });
    document.querySelectorAll('.image-gallery-wrapper img').forEach((el) => {
      el.setAttribute('data-cuelume-press', 'bloom');
    });
  }

  bind();

  function setupReveal() {
    const els = document.querySelectorAll('[data-reveal], .card-animate');
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach((el) => el.classList.add('in-view'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach((el) => io.observe(el));
  }

  document.addEventListener('astro:page-load', () => {
    setupReveal();
    decorateSounds();
    startQuincunx(); // persist mantém o canvas; isto cobre reload completo
  });
</script>
