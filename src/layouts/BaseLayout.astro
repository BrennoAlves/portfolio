---
const { pathname } = Astro.url;
const isProjetos = pathname.includes('/projetos');
const isPesquisas = pathname.includes('/pesquisas');
const titulo = isProjetos ? 'Criando' : isPesquisas ? 'Investigando' : 'Bem-vindo';
---

<div class="container">
  <header class="header">
    <a href="/" class="logo">{titulo}</a>
    <nav class="nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/projetos">Projetos</a></li>
        <li><a href="/pesquisas">Pesquisas</a></li>
      </ul>
    </nav>
  </header>
  <slot />
</div>

<style is:global>
  :root {
    --ease-out-strong: cubic-bezier(0.23, 1, 0.32, 1);
    --ease-in-out-strong: cubic-bezier(0.77, 0, 0.175, 1);
    --dur-fast: 150ms;
    --dur-base: 250ms;
    --dur-slow: 450ms;
  }

  .btn {
    border-radius: 80px;
    transition: transform 160ms var(--ease-out-strong);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-outline {
    border-width: 1px;
  }

  .badge {
    border-width: 1px;
  }

  .container {
    max-width: 64rem;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    padding: 2rem 2.5rem;
  }
  
  @media (min-width: 768px) {
    .container {
      gap: 5rem;
      padding: 4rem 2.5rem;
    }
  }
  
  .header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      padding-bottom: 0;
    }
  }

  .logo {
    font-size: 1.25rem;
    line-height: 1.75rem;
  }
  
  .nav {
    font-size: 0.875rem;
    line-height: 1.25rem;
    padding-top: 0.5%;
  }
  
  .nav ul {
    display: flex;
    align-items: center;
    white-space: nowrap;
    min-height: min-content;
  }
  
  .nav li {
    display: flex;
    align-items: center;
  }
  
  .nav a {
    display: flex;
    cursor: pointer;
    align-items: center;
    position: relative;
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms var(--ease-out-strong);
  }

  @media (hover: hover) and (pointer: fine) {
    .nav a:hover::after {
      transform: scaleX(1);
    }
  }
  
  .nav li + li:before {
    content: "/";
    margin: 0 0.5rem 0 0.75rem;
    opacity: 0.4;
  }
  
  .card-animate {
    animation: cardIn var(--dur-slow) var(--ease-out-strong) both;
  }

  .card-animate:nth-child(1) { animation-delay: 40ms; }
  .card-animate:nth-child(2) { animation-delay: 80ms; }
  .card-animate:nth-child(3) { animation-delay: 120ms; }
  .card-animate:nth-child(4) { animation-delay: 160ms; }
  .card-animate:nth-child(n+5) { animation-delay: 200ms; }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOnly {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    /* manter opacidade (comunicação), remover deslocamento */
    .card-animate {
      animation-name: fadeOnly;
    }
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
    .nav a::after {
      transition: none;
    }
  }
</style>
