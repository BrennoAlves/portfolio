---
import { ClientRouter } from "astro:transitions";
import { getImage } from "astro:assets";
import { TITULO_SITE, DESCRICAO_SITE } from "../consts";
import SiteChrome from "./SiteChrome.astro";
import perfilFoto from "../assets/perfil.webp";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  jsonLd?: Record<string, unknown>;
}

const { title = TITULO_SITE, description = DESCRICAO_SITE, jsonLd } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageOtimizada = await getImage({ src: perfilFoto, width: perfilFoto.width, height: perfilFoto.height });
const ogImage = new URL(ogImageOtimizada.src, Astro.site);
---

<!doctype html>
<html class="bg-base-100 text-base-content overflow-y-scroll" lang="pt-br" data-theme="nord">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2e3440" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={TITULO_SITE} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="google-site-verification" content="nyIFSFI9Pv2PK0MEmsDeAvpKgq_yo6fFx5UsRbDVA1o" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <ClientRouter />
    <script is:inline>
      document.documentElement.classList.add('js');
      (function () {
        function aplicaTema() {
          try {
            var t = localStorage.getItem('tema');
            if (t) document.documentElement.setAttribute('data-theme', t);
          } catch (e) {}
        }
        aplicaTema();
        document.addEventListener('astro:after-swap', aplicaTema);
      })();
    </script>
    <style is:global>
      /* saída mais rápida que entrada = timing assimétrico */
      ::view-transition-old(root) {
        animation: vtOut 150ms cubic-bezier(0.23, 1, 0.32, 1) both;
      }

      ::view-transition-new(root) {
        animation: vtIn 250ms cubic-bezier(0.23, 1, 0.32, 1) both;
      }

      @keyframes vtOut {
        to { opacity: 0; }
      }

      @keyframes vtIn {
        from { opacity: 0; transform: translateY(8px); }
      }
    </style>
  </head>
  <body>
    <SiteChrome>
      <slot />
    </SiteChrome>
  </body>
</html>
