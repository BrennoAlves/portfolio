---
import QuincunxFooter from "../components/QuincunxFooter.astro";

const { pathname } = Astro.url;
const isProjetos = pathname.includes('/projetos');
const isPesquisas = pathname.includes('/pesquisas');
const titulo = isProjetos ? 'Criando' : isPesquisas ? 'Investigando' : 'Bem-vindo';
---

<div class="container">
  <header class="header" transition:name="site-header">
    <a href="/" class="logo">{titulo}</a>
    <nav class="nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/projetos">Projetos</a></li>
        <li><a href="/pesquisas">Pesquisas</a></li>
        <li>
          <button id="theme-toggle" data-cuelume-toggle aria-label="Alternar tema claro/escuro">◐</button>
        </li>
      </ul>
    </nav>
  </header>
  <slot />
</div>
<QuincunxFooter />

<script>
  import { showEasterEgg } from '../scripts/easter-egg';
  import { initSpotlight } from '../scripts/spotlight';
  import { initThemeToggle } from '../scripts/theme-toggle';
  import { bindSounds, decorateSounds } from '../scripts/sound-decoration';
  import { initRevealObserver } from '../scripts/reveal-observer';

  showEasterEgg();
  initSpotlight();
  initThemeToggle();
  bindSounds();

  document.addEventListener('astro:page-load', () => {
    initRevealObserver();
    decorateSounds();
  });
</script>
