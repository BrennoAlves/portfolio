---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404, fora do intervalo | Brenno Alves">
  <main>
    <div class="error-container">
      <div class="content-wrapper">
        <p class="eyebrow">erro 404</p>
        <h1 class="err-title">Essa página saiu do intervalo de confiança.</h1>
        <p class="message">
          O endereço que você tentou não está na amostra. Mas já que chegou até aqui,
          tenta manter a linha dentro do intervalo. Aviso, é mais difícil do que parece.
        </p>

        <div class="game-card">
          <div class="game-hud">
            <span>n = <span id="gn">0</span></span>
            <span id="gstate">clique ou aperte espaço</span>
            <span>recorde <span id="grecord">0</span></span>
          </div>
          <canvas
            id="game"
            aria-label="Joguinho, mantenha a linha do gráfico dentro do intervalo entre as barras"
          ></canvas>
          <div class="game-foot">
            <p class="instructions">clique, toque ou espaço pra linha subir</p>
            <button id="restartBtn" class="btn btn-outline btn-sm" hidden>Jogar de novo</button>
          </div>
        </div>

        <div class="nav-buttons">
          <a href="/" class="btn btn-outline">← Voltar pra home</a>
          <a href="/projetos" class="btn btn-outline">Ver projetos</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .error-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 0;
  }

  .content-wrapper {
    max-width: 40rem;
    width: 100%;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .err-title {
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: clamp(1.5rem, 4.5vw, 2.25rem);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .message {
    opacity: 0.7;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 34rem;
  }

  .game-card {
    border: 1px solid var(--color-base-300);
    border-radius: var(--radius-box);
    background: var(--color-base-100);
    padding: 1rem;
  }

  .game-hud {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    opacity: 0.7;
    padding: 0 0.25rem 0.75rem;
  }

  #game {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--color-base-300);
    border-radius: calc(var(--radius-box) - 0.25rem);
    cursor: pointer;
    touch-action: manipulation;
  }

  .game-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0.25rem 0;
    min-height: 2.5rem;
  }

  .instructions {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    opacity: 0.5;
  }

  .nav-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  @media (max-width: 640px) {
    #game {
      aspect-ratio: 4 / 3;
    }

    .game-hud #gstate {
      display: none;
    }
  }
</style>

<script>
  import { play } from 'cuelume';

  function initSparkline404() {
    const canvas = document.getElementById('game');
    if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.on) return;
    canvas.dataset.on = '1';
    const cv = canvas; // narrowing não sobrevive a closures
    const ctx = cv.getContext('2d');
    if (!ctx) return;
    const g = ctx;

    const nEl = document.getElementById('gn');
    const recordEl = document.getElementById('grecord');
    const stateEl = document.getElementById('gstate');
    const restartBtn = document.getElementById('restartBtn');

    let w = 0, h = 0, dpr = 1;

    // cores do tema, cacheadas e renovadas quando o data-theme muda
    let cor = { primary: '', content: '', base300: '', error: '' };
    function leCores() {
      const s = getComputedStyle(document.documentElement);
      cor = {
        primary: s.getPropertyValue('--color-primary').trim(),
        content: s.getPropertyValue('--color-base-content').trim(),
        base300: s.getPropertyValue('--color-base-300').trim(),
        error: s.getPropertyValue('--color-error').trim(),
      };
    }
    leCores();
    new MutationObserver(() => {
      leCores();
      if (modo !== 'playing') desenha(); // parado ninguém repinta, troca de tema precisa
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    // estado do jogo
    type Modo = 'idle' | 'playing' | 'dead';
    let modo: Modo = 'idle';
    let n = 0;
    let recorde = 0;
    let bateuRecorde = false;
    try {
      recorde = parseInt(localStorage.getItem('sparkline404Record') || '0') || 0;
    } catch { /* sem storage, sem recorde */ }
    if (recordEl) recordEl.textContent = String(recorde);

    // jogador: ponta da série no x fixo, trilha atrás
    let py = 0;       // posição y (px de canvas)
    let vy = 0;       // velocidade y
    const trail: number[] = []; // y das últimas posições, 1 por coluna de trilha

    // barras (pares teto/chão com gap)
    type Barra = { x: number; gapY: number; gapH: number; passou: boolean };
    let barras: Barra[] = [];
    let proximaBarraEm = 0; // px até spawnar a próxima
    let vel = 0;            // velocidade horizontal atual (px/s)

    function resize() {
      const bw = cv.offsetWidth, bh = cv.offsetHeight;
      if (!bw || !bh) return;
      const wAntes = w, hAntes = h;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = cv.width = bw * dpr;
      h = cv.height = bh * dpr;
      if (modo === 'playing' && wAntes && hAntes) {
        // reescala as entidades pro novo tamanho (rotacionar o celular no meio do jogo
        // trocava a escala e matava o jogador na hora)
        const sx = w / wAntes, sy = h / hAntes;
        py *= sy;
        vy *= sy;
        for (let i = 0; i < trail.length; i++) trail[i] *= sy;
        for (const b of barras) { b.x *= sx; b.gapY *= sy; b.gapH *= sy; }
        proximaBarraEm *= sx;
      } else {
        py = h / 2;
        desenha(); // mudar width/height limpa o canvas; repinta o frame parado
      }
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    const PX = () => w * 0.28;            // x fixo do jogador
    const GRAV = () => h * 2.6;           // px/s²
    const IMPULSO = () => -h * 0.72;      // px/s
    const VEL_BASE = () => w * 0.34;      // px/s inicial
    const TRAIL_STEP = () => Math.max(3 * dpr, w / 160); // espaçamento da trilha

    function dificuldade() {
      // velocidade sobe e gap fecha devagar, com teto
      const f = Math.min(n / 40, 1);
      vel = VEL_BASE() * (1 + f * 0.9);
      return {
        gapH: h * (0.34 - f * 0.12),
        entreBarras: w * (0.34 - f * 0.08),
      };
    }

    function spawnBarra() {
      const { gapH } = dificuldade();
      const margem = h * 0.12;
      const gapY = margem + Math.random() * (h - gapH - margem * 2);
      barras.push({ x: w + w * 0.06, gapY, gapH, passou: false });
    }

    function reset() {
      n = 0;
      py = h / 2;
      vy = 0;
      trail.length = 0;
      barras = [];
      proximaBarraEm = w * 0.15;
      dificuldade();
      if (nEl) nEl.textContent = '0';
    }

    function comeca() {
      reset();
      modo = 'playing';
      if (stateEl) stateEl.textContent = 'dentro do intervalo';
      if (restartBtn) restartBtn.hidden = true;
      vy = IMPULSO() * 0.6;
      ultimoT = performance.now();
      agenda();
    }

    function morre() {
      modo = 'dead';
      play('whisper');
      if (stateEl) stateEl.textContent = 'fora do intervalo';
      if (restartBtn) restartBtn.hidden = false;
      bateuRecorde = n > recorde;
      if (bateuRecorde) {
        recorde = n;
        if (recordEl) recordEl.textContent = String(recorde);
        try { localStorage.setItem('sparkline404Record', String(recorde)); } catch { /* ok */ }
      }
      desenha(); // frame final com a mensagem
    }

    function pulo() {
      if (modo === 'playing') {
        vy = IMPULSO();
      } else {
        comeca();
      }
    }

    // ---- desenho ----

    function desenhaBarras() {
      g.fillStyle = cor.base300;
      g.strokeStyle = `color-mix(in oklch, ${cor.content} 25%, transparent)`;
      g.lineWidth = 1 * dpr;
      const bw = w * 0.055;
      for (const b of barras) {
        // teto
        g.beginPath();
        g.roundRect(b.x, -4 * dpr, bw, b.gapY + 4 * dpr, 3 * dpr);
        g.fill();
        g.stroke();
        // chão
        const yBaixo = b.gapY + b.gapH;
        g.beginPath();
        g.roundRect(b.x, yBaixo, bw, h - yBaixo + 4 * dpr, 3 * dpr);
        g.fill();
        g.stroke();
      }
    }

    function desenhaLinha() {
      if (!trail.length) return;
      const step = TRAIL_STEP();
      const x0 = PX() - (trail.length - 1) * step;

      // área sob a linha, cara de gráfico de área
      g.beginPath();
      g.moveTo(x0, trail[0]);
      for (let i = 1; i < trail.length; i++) g.lineTo(x0 + i * step, trail[i]);
      g.lineTo(PX(), py);
      g.lineTo(PX(), h);
      g.lineTo(x0, h);
      g.closePath();
      const grad = g.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, `color-mix(in oklch, ${cor.primary} 18%, transparent)`);
      grad.addColorStop(1, `color-mix(in oklch, ${cor.primary} 2%, transparent)`);
      g.fillStyle = grad;
      g.fill();

      // a linha em si
      g.beginPath();
      g.moveTo(x0, trail[0]);
      for (let i = 1; i < trail.length; i++) g.lineTo(x0 + i * step, trail[i]);
      g.lineTo(PX(), py);
      g.strokeStyle = cor.primary;
      g.lineWidth = 2 * dpr;
      g.lineJoin = 'round';
      g.stroke();

      // ponto na ponta, marcador de série
      g.beginPath();
      g.arc(PX(), py, 3.5 * dpr, 0, 6.2832);
      g.fillStyle = modo === 'dead' ? cor.error : cor.primary;
      g.fill();
    }

    function desenhaGrade() {
      // linhas de grade horizontais, bem fracas, cara de gráfico
      g.strokeStyle = cor.base300;
      g.lineWidth = 1;
      g.globalAlpha = 0.35;
      for (let i = 1; i < 4; i++) {
        const y = (h / 4) * i;
        g.beginPath();
        g.moveTo(0, y);
        g.lineTo(w, y);
        g.stroke();
      }
      g.globalAlpha = 1;
    }

    function texto(linhas: [string, number][]) {
      g.textAlign = 'center';
      g.fillStyle = cor.content;
      let y = h / 2 - (linhas.length - 1) * 14 * dpr;
      for (const [t, tam] of linhas) {
        g.font = `500 ${tam * dpr}px "IBM Plex Mono", monospace`;
        g.fillText(t, w / 2, y);
        y += 28 * dpr;
      }
    }

    function desenha() {
      g.clearRect(0, 0, w, h);
      desenhaGrade();
      desenhaBarras();
      desenhaLinha();

      if (modo === 'idle') {
        texto([['clique ou aperte espaço', 13]]);
      } else if (modo === 'dead') {
        g.globalAlpha = 0.92;
        texto([[`fora do intervalo com n = ${n}`, 14], [bateuRecorde ? 'novo recorde' : 'clique pra tentar de novo', 11]]);
        g.globalAlpha = 1;
      }
    }

    // ---- loop ----

    let raf = 0;
    let ultimoT = 0;
    let rodando = false;

    function agenda() {
      if (!rodando) {
        rodando = true;
        raf = requestAnimationFrame(tick);
      }
    }

    function para() {
      rodando = false;
      cancelAnimationFrame(raf);
    }

    function tick(agora: number) {
      if (!rodando) return;
      if (!w || !h) resize();
      const dt = Math.min((agora - ultimoT) / 1000, 0.032);
      ultimoT = agora;

      if (modo === 'playing') {
        // física do jogador
        vy += GRAV() * dt;
        py += vy * dt;

        // trilha anda na mesma velocidade das barras
        trail.push(py);
        const maxTrail = Math.floor((PX()) / TRAIL_STEP()) + 1;
        while (trail.length > maxTrail) trail.shift();

        // barras andam
        const { entreBarras } = dificuldade();
        proximaBarraEm -= vel * dt;
        if (proximaBarraEm <= 0) {
          spawnBarra();
          proximaBarraEm = entreBarras;
        }
        const bw = w * 0.055;
        for (const b of barras) {
          b.x -= vel * dt;
          if (!b.passou && b.x + bw < PX()) {
            b.passou = true;
            n++;
            if (nEl) nEl.textContent = String(n);
            play(n % 10 === 0 ? 'sparkle' : 'droplet');
          }
        }
        barras = barras.filter((b) => b.x + bw > -w * 0.02);

        // teto só segura (matar ali é injusto com quem clica rápido); chão mata
        const r = 4 * dpr;
        if (py < r) {
          py = r;
          vy = 0;
        }
        if (py > h - r) {
          morre();
          return;
        }
        for (const b of barras) {
          if (PX() + r > b.x && PX() - r < b.x + bw) {
            if (py - r < b.gapY || py + r > b.gapY + b.gapH) {
              morre();
              return;
            }
          }
        }
      }

      desenha();
      if (modo === 'playing') {
        raf = requestAnimationFrame(tick);
      } else {
        rodando = false;
      }
    }

    // ---- input ----

    cv.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      pulo();
    });

    function onKey(e: KeyboardEvent) {
      if (e.code !== 'Space' && e.code !== 'ArrowUp') return;
      // só captura o teclado com o jogo rolando ou com o canvas em foco/visível
      if (modo === 'playing') {
        e.preventDefault();
        pulo();
      } else if (document.activeElement === cv || document.activeElement === restartBtn) {
        e.preventDefault();
        pulo();
      }
    }
    function onVis() {
      if (document.hidden && modo === 'playing') {
        para();
        modo = 'idle';
        if (stateEl) stateEl.textContent = 'pausado, clique pra voltar';
        desenha();
      }
    }
    document.addEventListener('keydown', onKey);
    document.addEventListener('visibilitychange', onVis);
    cv.tabIndex = 0;

    restartBtn?.addEventListener('click', comeca);

    // ao sair da página (view transitions), solta os listeners de document e o
    // loop, senão revisitar o 404 empilhava uma segunda instância órfã
    document.addEventListener('astro:before-swap', () => {
      para();
      document.removeEventListener('keydown', onKey);
      document.removeEventListener('visibilitychange', onVis);
      window.removeEventListener('resize', resize);
    }, { once: true });

    // primeiro frame parado (idle), nada anima sem gesto do usuário
    py = h / 2;
    desenha();
  }

  initSparkline404();
  document.addEventListener('astro:page-load', initSparkline404);
</script>
