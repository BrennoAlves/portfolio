---
import Layout from "../layouts/Layout.astro";
import TagBadges from "../components/TagBadges.astro";
import ResearchCard from "../components/ResearchCard.astro";
import { projetosDestaque } from "../consts";
import { getCollection } from "astro:content";

const pesquisas = await getCollection("pesquisas");

const homeDescription = "Sócio na DataClix. De estagiário de dados a analista a sócio. Projetos e pesquisas em dados, automação e gestão de desenvolvimento.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Brenno Alves",
  "jobTitle": "CEO",
  "worksFor": {
    "@type": "Organization",
    "name": "DataClix",
    "url": "https://www.dataclix.com.br/"
  },
  "url": "https://brennoalves.com.br",
  "sameAs": [
    "https://www.linkedin.com/in/brennonogueiraalves/",
    "https://github.com/BrennoAlves"
  ],
  "email": "brenno1231@outlook.com",
  "description": homeDescription
};

const skills = [
  {
    area: "Dados & Análise",
    items: ["Python", "Pandas", "GeoPandas", "Matplotlib", "Seaborn", "Jupyter", "Estatística"]
  },
  {
    area: "ML & Automação",
    items: ["NLP", "SentenceTransformer", "AWS Textract", "Selenium", "BeautifulSoup", "CLI"]
  },
  {
    area: "Gestão & Negócios",
    items: ["Gestão de Projetos", "Entrega de Soluções", "Dados Públicos", "Políticas Públicas"]
  }
];
---

<Layout description={homeDescription} jsonLd={personSchema}>
  <main>
    <div class="flex flex-col gap-12">
      <article class="md:flex-row-reverse md:justify-end md:gap-12">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="col-span-2 flex flex-col gap-4 md:gap-6 my-auto">
            <h1 class="text-3xl hero-title">Prazer, Brenno.</h1>
            <p class="w-auto sm:w-[85%] md:w-[90%] leading-6 text-justify opacity-70 hero-in" style="--d: 350ms">
              Trabalho com dados e tecnologia. Fiz meu primeiro curso de programação aos 10 anos. Fui pra Economia por causa da estatística, comecei como estagiário de dados, virei analista e hoje sou sócio na <a class="font-normal text-primary" href="https://www.dataclix.com.br/">DataClix</a>, onde trabalho com dados e gestão de projetos de desenvolvimento. Este site tem alguns desses projetos de estudos. Nas horas vagas, faço pão, tento tocar baixo e cuido da minha gata gorda.
            </p>
            <div class="nav hero-in" style="--d: 500ms">
              <ul>
                <li>
                  <a href="https://www.linkedin.com/in/brennonogueiraalves/" rel="noreferrer" target="_blank" aria-label="LinkedIn do Brenno">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </a>
                </li>
                <li>
                  <a href="https://github.com/BrennoAlves" rel="noreferrer" target="_blank" aria-label="GitHub do Brenno">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                </li>
                <li>
                  <a href="mailto:brenno1231@outlook.com" aria-label="Email do Brenno">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                  </a>
                </li>
              </ul>
            </div>
          </div>
          <div class="mx-auto mt-6 sm:mt-0 hero-photo" style="--d: 250ms">
            <div class="avatar flex-items-center mx-auto sm:flex-row">
              <div class="w-60 rounded">
                <img src="/perfil.webp" alt="Foto do Brenno" loading="lazy" decoding="async" />
              </div>
            </div>
          </div>
        </div>
      </article>

      <section class="flex flex-col gap-4">
        <div class="flex flex-col gap-3">
          {skills.map((grupo, i) => (
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2" data-reveal style={`--reveal-i: ${i}`}>
              <span class="text-xs opacity-50 uppercase tracking-widest w-full sm:w-auto sm:min-w-[10rem]">{grupo.area}</span>
              <div class="flex flex-wrap gap-2">
                {grupo.items.map((item) => (
                  <span class="badge badge-ghost badge-sm">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="flex flex-col gap-6">
        <div class="text-center" data-reveal>
          <h2 class="text-2xl">Projetos e Pesquisas</h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
          {projetosDestaque.map(([nome, projeto]) => (
            <div class="card bg-base-100 shadow-lg hover:shadow-xl transition-shadow duration-300 rounded-2xl card-animate">
              <div class="card-body p-5 flex flex-col">
                <div class="flex items-start justify-between mb-3">
                  <h3 class="text-lg font-semibold flex-1">{nome}</h3>
                </div>

                <p class="text-base-content/70 text-sm leading-relaxed mb-4">
                  {projeto.descricao}
                </p>

                <div class="mb-4">
                  <TagBadges tags={projeto.tags} maxTags={3} />
                </div>

                <div class="card-actions justify-end mt-auto">
                  <a href={projeto.url} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
                    Ver Projeto
                  </a>
                </div>
              </div>
            </div>
          ))}
          {pesquisas.map((pesquisa) => (
            <ResearchCard
              titulo={pesquisa.data.titulo}
              descricao={pesquisa.data.descricao}
              tags={pesquisa.data.tags}
              url={`/pesquisas/${pesquisa.id}`}
              imagemCapa={pesquisa.data.imagemCapa}
              maxTags={3}
            />
          ))}
        </div>

        <div class="flex gap-4 justify-center flex-wrap mt-4" data-reveal>
          <a href="/projetos" class="btn btn-outline">Outros Projetos</a>
          <a href="/pesquisas" class="btn btn-outline">Outras Pesquisas</a>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hero-in {
    opacity: 0;
    animation: heroIn 800ms var(--ease-out-strong) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes heroIn {
    from {
      opacity: 0;
      transform: translateY(18px);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  .hero-photo {
    opacity: 0;
    animation: photoIn 900ms var(--ease-out-strong) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes photoIn {
    from {
      opacity: 0;
      transform: scale(0.94) translateY(12px);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in,
    .hero-photo {
      animation-name: heroFadeOnly;
    }
    @keyframes heroFadeOnly {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  }
</style>

{/* is:inline: o minificador (lightningcss) descarta animation-timeline; inline pula o pipeline */}
<style is:inline>
  @supports (animation-timeline: scroll()) {
    .hero-photo img {
      animation: heroParallax linear both;
      animation-timeline: scroll(root);
      animation-range: 0px 500px;
    }

    @keyframes heroParallax {
      to {
        transform: translateY(36px);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo img {
      animation: none;
    }
  }
</style>

<script>
  // título decodifica de glifos embaralhados, esquerda → direita
  function scramble() {
    const el = document.querySelector('.hero-title');
    if (!(el instanceof HTMLElement) || el.dataset.done) return;
    el.dataset.done = '1';
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const titulo = el; // narrowing não sobrevive a closures
    const alvo = el.textContent?.trim() ?? '';
    if (!alvo) return;
    const glifos = '01<>[]{}/#$%&*+=~';
    const dur = 900;
    const t0 = performance.now();
    function frame(agora: number) {
      const p = Math.min(1, (agora - t0) / dur);
      const travados = Math.floor(alvo.length * p);
      let saida = '';
      for (let i = 0; i < alvo.length; i++) {
        const c = alvo[i];
        saida += i < travados || c === ' ' || c === ',' || c === '.'
          ? c
          : glifos[(Math.random() * glifos.length) | 0];
      }
      titulo.textContent = saida;
      if (p < 1) setTimeout(() => requestAnimationFrame(frame), 35);
      else titulo.textContent = alvo;
    }
    requestAnimationFrame(frame);
  }
  scramble();
  document.addEventListener('astro:page-load', scramble);
</script>
