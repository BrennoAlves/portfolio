---
import Layout from "../layouts/Layout.astro";
import PageIntro from "../components/PageIntro.astro";
import ResearchCard from "../components/ResearchCard.astro";
import { getCollection } from 'astro:content';

const pesquisas = await getCollection('pesquisas');
---

<Layout title="Pesquisas | Brenno Alves" description="Pesquisas com dados públicos: ENEM, Minha Casa Minha Vida e políticas públicas.">
  <main>
    <div class="flex flex-col gap-12">
      <PageIntro
        title="Pesquisas"
        description="Análises com dados públicos. Python, estatística e alguns insights sobre políticas públicas."
      />

      <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
        {pesquisas.map((pesquisa) => (
          <ResearchCard
            titulo={pesquisa.data.titulo}
            descricao={pesquisa.data.descricao}
            tags={pesquisa.data.tags}
            url={`/pesquisas/${pesquisa.id}`}
            imagemCapa={pesquisa.data.imagemCapa}
            includeDate={pesquisa.data.data}
            ctaLabel="Ler Análise"
          />
        ))}
      </div>
    </div>
  </main>
</Layout>
