---
import Layout from "../layouts/Layout.astro";
import { getCollection } from 'astro:content';

const pesquisas = await getCollection('pesquisas');
---

<Layout title="Pesquisas | Brenno Alves">
  <main>
    <div class="flex flex-col gap-12">
      <div class="flex flex-col gap-6 md:gap-8">
        <h1 class="text-3xl">Pesquisas</h1>
        <p class="w-auto sm:w-[85%] md:w-[90%] leading-6 text-justify opacity-70">
          Análises com dados públicos. Python, estatística e alguns insights sobre políticas públicas.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
        {pesquisas.map((pesquisa) => (
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 rounded-2xl card-animate">
            <figure class="h-48 overflow-hidden">
              <img
                src={pesquisa.data.imagemCapa}
                alt={pesquisa.data.titulo}
                class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
              />
            </figure>
            <div class="card-body p-6 flex flex-col">
              <h2 class="card-title text-xl font-semibold">
                MCMV no Sudeste: Dados e Território
              </h2>

              <p class="text-base-content/70 text-sm leading-relaxed mb-4">
                {pesquisa.data.descricao}
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {pesquisa.data.tags.map((tag, tagIndice) => (
                  <div class={`badge border-0 font-medium ${
                    tagIndice % 4 === 0 ? 'bg-primary/20 text-primary' :
                    tagIndice % 4 === 1 ? 'bg-secondary/20 text-secondary' :
                    tagIndice % 4 === 2 ? 'bg-accent/20 text-accent' : 'bg-info/20 text-info'
                  }`}>
                    {tag}
                  </div>
                ))}
                <div class="badge border-0 bg-warning/20 text-warning font-medium">
                  {pesquisa.data.data}
                </div>
              </div>

              <div class="card-actions justify-end mt-auto">
                <a href={`/pesquisas/${pesquisa.slug}`} class="btn btn-outline btn-sm">
                  Ler Análise
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
