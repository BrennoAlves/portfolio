---
import Layout from "../../layouts/Layout.astro";
import ImageGallery from "../../components/ImageGallery.astro";
import ArticleHeader from "../../components/ArticleHeader.astro";
import MethodologySection from "../../components/MethodologySection.astro";
import { getEntry, render } from 'astro:content';
import { getImage } from 'astro:assets';
import perfilFoto from "../../assets/perfil.webp";
import '../../styles/prose.css';

const entry = await getEntry('pesquisas', 'distribuicao-mcmv');
if (!entry) {
  throw new Error('Pesquisa não encontrada');
}
const { Content } = await render(entry);
const { titulo, subtitulo, tags, data } = entry.data;

const capaOtimizada = await getImage({ src: entry.data.imagemCapa, width: entry.data.imagemCapa.width });
const perfilOtimizado = await getImage({ src: perfilFoto, width: perfilFoto.width, height: perfilFoto.height });
const dataPublicacao = `${data}-01-01`;
const urlArtigo = new URL(`/pesquisas/${entry.id}/`, Astro.site).toString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": titulo,
  "description": entry.data.descricao,
  "image": new URL(capaOtimizada.src, Astro.site).toString(),
  "datePublished": dataPublicacao,
  "dateModified": dataPublicacao,
  "inLanguage": "pt-BR",
  "author": {
    "@type": "Person",
    "name": "Brenno Alves",
    "url": "https://www.brennoalves.com"
  },
  "publisher": {
    "@type": "Person",
    "name": "Brenno Alves",
    "url": "https://www.brennoalves.com",
    "logo": {
      "@type": "ImageObject",
      "url": new URL(perfilOtimizado.src, Astro.site).toString()
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": urlArtigo
  },
  "url": urlArtigo
};

const metodologia = [
  {
    title: 'Bases de dados utilizadas:',
    list: [
      'Contratos do Programa Minha Casa, Minha Vida (Ministério do Desenvolvimento Regional, 2009-2020)',
      'Estimativas populacionais dos municípios (IBGE/Censo 2010 e projeções)',
      'Malhas geográficas municipais (IBGE)'
    ]
  },
  {
    title: 'Ferramentas e técnicas:',
    list: [
      'Python (Pandas, GeoPandas, Matplotlib, Seaborn) para limpeza, processamento e visualização',
      'Regressão linear com transformação logarítmica para análise comparativa entre municípios de diferentes portes',
      'Mapas de calor (heatmaps) para visualização espacial da distribuição'
    ]
  }
];
---

<Layout title={titulo} description={entry.data.descricao} jsonLd={articleSchema}>
  <article class="max-w-4xl mx-auto px-4 md:px-6 py-6 md:py-12 animate-fade-in">
    <ArticleHeader title={titulo} subtitle={subtitulo} tags={tags} date={data} transitionName={`pesquisa-titulo-${entry.id}`} />

    <ImageGallery>
      <div class="prose-custom max-w-none">
        <Content />
      </div>
    </ImageGallery>

    <MethodologySection items={metodologia} />
  </article>
</Layout>

<style is:global>
  /* Estilo específico desta página */
  .prose-custom > h2:first-of-type + h3 {
    background: hsl(var(--b2));
    padding: 2rem;
    border-radius: 1rem;
    margin-top: 2rem;
  }
</style>
