---
import ProjetosLayout from "../layouts/Projetos.astro";
import PageIntro from "../components/PageIntro.astro";
import TagBadges from "../components/TagBadges.astro";
import { projetos } from "../consts";
---

<ProjetosLayout>
  <main>
    <div class="flex flex-col gap-12">
      <PageIntro
        title="Projetos"
        description="Aqui estão projetos que desenvolvi para testar conceitos, ferramentas e experimentar soluções."
      />

      <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
        {Object.entries(projetos).map(([nome, projeto]) => (
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 rounded-2xl card-animate">
            <div class="card-body p-6 flex flex-col">
              <div class="flex items-start justify-between mb-3">
                <h2 class="card-title text-xl font-semibold flex-1">{nome}</h2>
              </div>

              <p class="text-base-content/70 text-sm leading-relaxed mb-4">
                {projeto.descricao}
              </p>

              <div class="mb-6">
                <TagBadges tags={projeto.tags} />
              </div>

              <div class="card-actions justify-end mt-auto">
                <a href={projeto.url} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
                  Ver Projeto
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</ProjetosLayout>
