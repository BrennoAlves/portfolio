---
import ProjetosLayout from "../layouts/Projetos.astro";
import PageIntro from "../components/PageIntro.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import { projetos } from "../consts";
import { getCollection } from 'astro:content';

const projetosComArtigo = await getCollection('projetos');
---

<ProjetosLayout description="Projetos de automação, NLP, OCR e análise de dados desenvolvidos por Brenno Alves.">
  <main>
    <div class="flex flex-col gap-12">
      <PageIntro
        title="Projetos"
        description="Aqui estão projetos que desenvolvi para testar conceitos, ferramentas e experimentar soluções."
      />

      {projetosComArtigo.length > 0 && (
        <div class="flex flex-col gap-6">
          <div class="section-head">
            <h2 class="text-xl font-semibold">Com artigo completo</h2>
            <span class="section-rule" aria-hidden="true"></span>
            <span class="section-n">n = {projetosComArtigo.length}</span>
          </div>
          <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
            {projetosComArtigo.map((projeto) => (
              <ResearchCard
                titulo={projeto.data.titulo}
                descricao={projeto.data.descricao}
                tags={projeto.data.tags}
                url={`/projetos/${projeto.id}`}
                includeDate={projeto.data.data}
                ctaLabel="Ler artigo"
                tipo="Artigo"
              />
            ))}
          </div>
        </div>
      )}

      <div class="flex flex-col gap-6">
        <div class="section-head">
          <h2 class="text-xl font-semibold">Outros projetos</h2>
          <span class="section-rule" aria-hidden="true"></span>
          <span class="section-n">n = {Object.keys(projetos).length}</span>
        </div>
        <div class="grid gap-6 sm:grid-cols-1 md:grid-cols-2">
          {Object.entries(projetos).map(([nome, projeto]) => (
            <ProjectCard nome={nome} descricao={projeto.descricao} tags={projeto.tags} url={projeto.url} />
          ))}
        </div>
      </div>
    </div>
  </main>
</ProjetosLayout>
