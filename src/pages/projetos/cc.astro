---
import Layout from "../../layouts/Layout.astro";
import ImageGallery from "../../components/ImageGallery.astro";
import ArticleHeader from "../../components/ArticleHeader.astro";
import MethodologySection from "../../components/MethodologySection.astro";
import { getEntry, render } from 'astro:content';
import '../../styles/prose.css';

const entry = await getEntry('projetos', 'cc');
if (!entry) {
  throw new Error('Projeto não encontrado');
}
const { Content } = await render(entry);
const { titulo, subtitulo, tags, data, repo } = entry.data;

const dataPublicacao = `${data}-01-01`;
const urlArtigo = new URL(`/projetos/${entry.id}/`, Astro.site).toString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": titulo,
  "description": entry.data.descricao,
  "datePublished": dataPublicacao,
  "dateModified": dataPublicacao,
  "inLanguage": "pt-BR",
  "author": {
    "@type": "Person",
    "name": "Brenno Alves",
    "url": "https://www.brennoalves.com"
  },
  "publisher": {
    "@type": "Person",
    "name": "Brenno Alves",
    "url": "https://www.brennoalves.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": urlArtigo
  },
  "url": urlArtigo
};

const stack = [
  {
    title: 'Linguagem e bibliotecas',
    list: [
      'Go 1.26, binário estático sem dependências de runtime no servidor',
      'gopsutil para leitura de disco, memória e CPU multiplataforma',
      'gopkg.in/yaml.v3 para o config, net/http da stdlib para a API e os healthchecks (sem framework)'
    ]
  },
  {
    title: 'Deploy e operação',
    list: [
      'Cross-compile no Mac (GOOS=linux GOARCH=amd64) e scp do binário para o servidor',
      'systemd com usuário de sistema dedicado, sem login, e sandbox restrito (ProtectSystem=strict, PrivateTmp)',
      'Estado (mensagens represadas, cooldown de alerta) persistido em state.json no diretório do serviço'
    ]
  }
];
---

<Layout title={titulo} description={entry.data.descricao} jsonLd={articleSchema}>
  <article class="max-w-4xl mx-auto px-4 md:px-6 py-6 md:py-12 animate-fade-in">
    <ArticleHeader title={titulo} subtitle={subtitulo} tags={tags} date={data} repoUrl={repo} transitionName={`projeto-titulo-${entry.id}`} />

    <ImageGallery>
      <div class="prose-custom max-w-none">
        <Content />
      </div>
    </ImageGallery>

    <MethodologySection title="Stack e Como Rodar" items={stack} />
  </article>
</Layout>
